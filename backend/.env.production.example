# CareerPilot AI Backend Production Environment
# Copy these values into Render Environment Variables.
# Do not commit real secrets.

ENVIRONMENT=production
APP_ENV=production
LOG_LEVEL=info

# Render injects this automatically from render.yaml.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/careerpilot

# Set after Vercel deploy.
FRONTEND_URL=https://your-vercel-app.vercel.app

# Comma-separated allowed frontend origins.
BACKEND_CORS_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:3000

# Render can generate this from render.yaml.
SECRET_KEY=replace-with-secure-generated-secret
